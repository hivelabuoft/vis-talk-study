{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "Stage 1 Critique Study",
        "version": "1.0",
        "authors": [
            "Matthew Varona",
            "Jenny Oh",
            "Emily Wall",
            "Carolina Nobre"
        ],
        "date": "2026-02-11",
        "description": "Stage 1 study for thinkaloud component",
        "organizations": [
            "University of Toronto",
            "Emory University"
        ]
    },
    "uiConfig": {
        "contactEmail": "varona@cs.toronto.edu",
        "helpTextPath": "!stage-1/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": false,
        "autoDownloadStudy": false,
        "withSidebar": true,
        "recordAudio": false,
        "urlParticipantIdParam": "PROLIFIC_PID",
        "studyEndMsg": "Thank you for completing the study! Return to Prolific: [https://app.prolific.com/submissions/complete?cc=C147KGIL](https://app.prolific.com/submissions/complete?cc=C147KGIL)"
    },
    "importedLibraries": [
        "mic-check",
        "calvi"
    ],
    "components": {
        "consent": {
            "type": "markdown",
            "path": "!stage-1/assets/intro-1.md",
            "response": [
                {
                    "id": "q-sidebar",
                    "prompt": "I consent to participate in this study.",
                    "location": "belowStimulus",
                    "type": "checkbox",
                    "options": ["Yes"]
                }
            ]
        },
        "introduction": {
            "type": "markdown",
            "path": "!stage-1/assets/intro-2.md",
            "response": []
        },
        "calvi-intro": {
            "type": "markdown",
            "path": "!stage-1/assets/calvi-intro.md",
            "response": []
        },
        "demographics": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "age",
                    "prompt": "What is your age?",
                    "required": true,
                    "type": "numerical",
                    "min": 18,
                    "max": 120
                },
                {
                    "id": "gender",
                    "prompt": "What is your gender identity?",
                    "required": true,
                    "type": "radio",
                    "options": ["Woman", "Man", "Non-binary", "Prefer not to say"],
                    "withOther": true
                },
                {
                    "id": "education",
                    "prompt": "What is the highest level of education you have completed?",
                    "required": true,
                    "type": "radio",
                    "options": ["Less than high school", "High school or equivalent", "Some college", "Bachelor's degree", "Graduate degree"],
                    "withOther": true
                }
            ]
        },
        "media-questionnaire": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "media-matrix",
                    "prompt": "How often do you get news from the following sources?",
                    "type": "matrix-radio",
                    "answerOptions": ["Never", "Hardly ever", "Sometimes", "Often"],
                    "questionOptions": ["Print newspapers", "Radio", "Television news (including local, national, and cable news)", "Facebook", "Reddit", "X (formerly Twitter)", "Instagram", "TikTok", "YouTube", "For this item only, please select 'Often'", "News apps on your phone (e.g., Apple News, Google News, etc.)", "News websites (e.g., CNN.com, FoxNews.com, etc.)"]
                }
            ]
        },
        "issue-familiarity": {
            "type": "questionnaire",
            "instructionLocation": "aboveStimulus",
            "response": [
                {
                    "id": "issue-familiarity-matrix",
                    "prompt": "Please rate how informed you would consider yourself about the following topics:",
                    "secondaryText": "There are no right or wrong answers, so please answer honestly based on your own feelings of familiarity with each topic.",
                    "type": "matrix-radio",
                    "answerOptions": ["I have never heard of it", "I’ve heard of it, but know almost nothing", "I know a little", "I know a fair amount", "I know a lot"],
                    "questionOptions": ["Gun control", "United States military spending", "Different branches of government", "Immigration policy"]
                }
            ]
        },
        "belief-questionnaire": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "belief-matrix",
                    "prompt": "Please rate how much you agree or disagree with the following statements:",
                    "type": "matrix-radio",
                    "questionOrder": "random",
                    "answerOptions": ["Strongly Disagree", "Disagree", "Slightly Disagree", "Slightly Agree", "Agree", "Strongly Agree"],
                    "questionOptions": ["Gun ownership should be more strictly regulated in the United States.", "The United States Government should increase its military budget to protect national security.", "I approve of the way Donald Trump is handling his job as President.", "Undocumented immigrants should be deported from the United States."]
                }
            ]
        },
        "belief-lean": {
            "type": "react-component",
            "path": "!stage-1/assets/belief_lean.tsx",
            "response": []
        },
        "stimulus-view-chart": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "nextButtonEnableTime": 30000,
            "instruction": "Please read and understand the following chart. Then, click 'Next' to proceed.",
            "parameters": {
                "phase": "view",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": null
            },
            "response": []
        },
        "stimulus-pre-words": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "instruction": "Please fill out the text box below.",
            "parameters": {
                "phase": "pre_words",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": null
            },
            "response": [
                {
                    "id": "pre_valence",
                    "type": "radio",
                    "location": "belowStimulus",
                    "horizontal": true,
                    "prompt": "Overall, would you say you like or dislike this chart?",
                    "secondaryText": "Note that this question is asking about your opinion of the chart (i.e. the entirety of the image above), not the specific topic it covers.",
                    "options": ["Strongly Dislike", "Dislike", "Neutral", "Like", "Strongly Like"],
                    "required": true
                },
                {
                    "id": "pre_word_1",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": "Please write 3 words that, in your opinion, best describe this chart.",
                    "secondaryText": "Word 1",
                    "required": true,
                    "placeholder": ""
                },
                {
                    "id": "pre_word_2",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": " ",
                    "secondaryText": "Word 2",
                    "required": true,
                    "placeholder": ""
                },
                {
                    "id": "pre_word_3",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": " ",
                    "secondaryText": "Word 3",
                    "required": true,
                    "placeholder": ""
                }
            ]
        },
        "stimulus-getready": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "instruction": "You have now rated this chart and chosen words to describe it. For this next task, please explain your opinion by talking about the chart itself---for example, what you noticed about it that led to your impression. <br/><br/> Please ensure you are not muted and that your browser is capturing audio. You will see a red visualization of your audio input in the top right of your screen. Audio recording is required to complete the study and receive payment.<br/><br/> You will be asked to record for at least 30 seconds. When you are ready, click \"Start Recording\".",
            "nextButtonText": "Start recording",
            "response": []
        },
        "stimulus-record": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "recordAudio": true,
            "instruction": "You have now rated this chart and chosen words to describe it. For this next task, please explain your opinion by talking about the chart itself---for example, what you noticed about it that led to your impression. <br/><br/> Please ensure you are not muted and that your browser is capturing audio. You will see a red visualization of your audio input in the top right of your screen. Audio recording is required to complete the study and receive payment.<br/><br/> Please record for at least 30 seconds. When you are finished, click \"Finish Recording\".",
            "nextButtonText": "Finish recording",
            "parameters": {
                "phase": "record",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": null
            },
            "nextButtonEnableTime": 30000,
            "response": []
        },
        "stimulus-post-words": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "parameters": {
                "phase": "post_words",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": null
            },
            "instruction": "Audio recording has stopped. Please fill in the questions below.",
            "response": [
                {
                    "id": "post-stimulus-response",
                    "required": true,
                    "prompt": "Would you say that your opinion of this chart has changed significantly after speaking about it?",
                    "type": "radio",
                    "options": ["Yes, I have changed my opinion", "No, my opinion has not changed"]
                },
                {
                    "id": "post-stimulus-description",
                    "required": false,
                    "prompt": "If your opinion has changed, please explain what caused this to change, and what your new opinion is.",
                    "secondaryText": "If your opinion has not changed, you may leave this field blank.",
                    "type": "shortText",
                    "placeholder": "Explain your updated opinion here"
                }
            ]
        },
        "example-view-chart": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "nextButtonEnableTime": 30000,
            "instruction": "Please read and understand the following chart. Then, click 'Next' to proceed.",
            "parameters": {
                "phase": "view",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": "!stage-1/assets/mariah.png"
            },
            "response": []
        },
        "example-pre-words": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "instruction": "Please fill out the text box below.",
            "parameters": {
                "phase": "pre_words",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": "!stage-1/assets/mariah.png"
            },
            "response": [
                {
                    "id": "pre_valence",
                    "type": "radio",
                    "location": "belowStimulus",
                    "horizontal": true,
                    "prompt": "Overall, would you say you like or dislike this chart?",
                    "secondaryText": "Note that this question is asking about your opinion of the chart (i.e. the entirety of the image above), not the specific topic it covers.",
                    "options": ["Strongly Dislike", "Dislike", "Neutral", "Like", "Strongly Like"],
                    "required": true
                },
                {
                    "id": "pre_word_1",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": "Please write 3 words that, in your opinion, best describe this chart.",
                    "secondaryText": "Word 1",
                    "required": true,
                    "placeholder": ""
                },
                {
                    "id": "pre_word_2",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": " ",
                    "secondaryText": "Word 2",
                    "required": true,
                    "placeholder": ""
                },
                {
                    "id": "pre_word_3",
                    "type": "shortText",
                    "location": "belowStimulus",
                    "prompt": " ",
                    "secondaryText": "Word 3",
                    "required": true,
                    "placeholder": ""
                }
            ]
        },
        "example-getready": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "instruction": "You have now rated this chart and chosen words to describe it. For this next task, please explain your opinion by talking about the chart itself---for example, what you noticed about it that led to your impression. <br/><br/> Please ensure you are not muted and that your browser is capturing audio. You will see a red visualization of your audio input in the top right of your screen. Audio recording is required to complete the study and receive payment.<br/><br/> You will be asked to record for at least 30 seconds. When you are ready, click \"Start Recording\".",
            "nextButtonText": "Start recording",
            "parameters": {
                "imagePath": "!stage-1/assets/mariah.png"
            },
            "response": []
        },
        "example-record": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "recordAudio": true,
            "instruction": "You have now rated this chart and chosen words to describe it. For this next task, please explain your opinion by talking about the chart itself---for example, what you noticed about it that led to your impression. <br/><br/> Please ensure you are not muted and that your browser is capturing audio. You will see a red visualization of your audio input in the top right of your screen. Audio recording is required to complete the study and receive payment.<br/><br/> Please record for at least 30 seconds. When you are finished, click \"Finish Recording\".",
            "nextButtonText": "Finish recording",
            "parameters": {
                "phase": "record",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": "!stage-1/assets/mariah.png"
            },
            "nextButtonEnableTime": 30000,
            "response": []
        },
        "example-post-words": {
            "type": "react-component",
            "path": "!stage-1/assets/thinkaloud_stimulus.tsx",
            "parameters": {
                "phase": "post_words",
                "issueId": null,
                "side": null,
                "proposition": null,
                "imagePath": "!stage-1/assets/mariah.png"
            },
            "instruction": "Audio recording has stopped. Please fill in the questions below.",
            "response": [
                {
                    "id": "post-stimulus-response",
                    "required": true,
                    "prompt": "Would you say that your opinion of this chart has changed significantly after speaking about it?",
                    "type": "radio",
                    "options": ["Yes, I have changed my opinion", "No, my opinion has not changed"]
                },
                {
                    "id": "post-stimulus-description",
                    "required": false,
                    "prompt": "If your opinion has changed, please explain what caused this to change, and what your new opinion is.",
                    "secondaryText": "If your opinion has not changed, you may leave this field blank.",
                    "type": "shortText",
                    "placeholder": "Explain your updated opinion here"
                }
            ]
        },
        "example-end": {
            "type": "markdown",
            "path": "!stage-1/assets/example_end.md",
            "response": []
        },
        "break": {
            "type": "markdown",
            "path": "!stage-1/assets/break.md",
            "nextButtonEnableTime": 5000,
            "response": []
        },
        "congruence-setter_gun_mil": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["gun", "mil"] },
            "response": []
        },
        "congruence-setter_gun_trump": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["gun", "trump"] },
            "response": []
        },
        "congruence-setter_gun_immig": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["gun", "immig"] },
            "response": []
        },
        "congruence-setter_mil_trump": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["mil", "trump"] },
            "response": []
        },
        "congruence-setter_mil_immig": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["mil", "immig"] },
            "response": []
        },
        "congruence-setter_trump_immig": {
            "type": "react-component",
            "path": "!stage-1/assets/congruence_setter.tsx",
            "parameters": { "congruentIssues": ["trump", "immig"] },
            "response": []
        },
        "post-study-feedback": {
            "type": "questionnaire",
            "instruction": "Thank you very much for participating in our study! Your feedback is greatly appreciated and will help us improve our research.",
            "response": [
                {
                    "id": "post_study_feedback",
                    "prompt": "Do you have any feedback about the study? If so, please share it below.",
                    "type": "longText",
                    "required": false,
                    "placeholder": "Enter your feedback here"
                }
            ]
        }
    },
    "sequence": {
        "order": "fixed",
        "components": [
            "consent",
            "introduction",
            "$mic-check.co.audioTest",
            "demographics",
            "media-questionnaire",
            "issue-familiarity",
            "belief-questionnaire",
            "calvi-intro",
            "$calvi.components.N7",
            {
                "id": "calvi_task",
                "order": "latinSquare",
                "components": [
                    "$calvi.components.T37",
                    "$calvi.components.T50",
                    "$calvi.components.T30",
                    "$calvi.components.T42",
                    "$calvi.components.T43",
                    "$calvi.components.N8",
                    "$calvi.components.N11"
                ]
            },
            "break",
            {
                "id": "congruence_assignment",
                "order": "latinSquare",
                "numSamples": 1,
                "components": [
                    "congruence-setter_gun_mil",
                    "congruence-setter_gun_trump",
                    "congruence-setter_gun_immig",
                    "congruence-setter_mil_trump",
                    "congruence-setter_mil_immig",
                    "congruence-setter_trump_immig"
                ]
            },
            {
                "id": "sample_q",
                "order": "fixed",
                "components": [
                    "example-view-chart",
                    "example-pre-words",
                    "example-getready",
                    "example-record",
                    "example-post-words",
                    "example-end"
                ]
            },
            {
                "id": "thinkaloud_block",
                "order": "latinSquare",
                "components": [
                    {
                        "id": "gun-stimuli",
                        "order": "dynamic",
                        "functionPath": "!stage-1/assets/issue_runner.ts",
                        "parameters": { "issueId": "gun" }
                    },
                    {
                        "id": "mil-stimuli",
                        "order": "dynamic",
                        "functionPath": "!stage-1/assets/issue_runner.ts",
                        "parameters": { "issueId": "mil" }
                    },
                    {
                        "id": "trump-stimuli",
                        "order": "dynamic",
                        "functionPath": "!stage-1/assets/issue_runner.ts",
                        "parameters": { "issueId": "trump" }
                    },
                    {
                        "id": "immig-stimuli",
                        "order": "dynamic",
                        "functionPath": "!stage-1/assets/issue_runner.ts",
                        "parameters": { "issueId": "immig" }
                    }
                ],
                "interruptions": [
                    {
                        "spacing": 1,
                        "firstLocation": 1,
                        "components": ["break"]
                    }
                ]
            },
            "post-study-feedback"
        ]
    }
}